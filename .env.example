# =============================================================================
# Montinho Nutrition Strategy — Variáveis de ambiente
#
# Copie este arquivo para .env.local e preencha com os valores do seu
# projeto Supabase (Painel → Settings → API).
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Schema do banco (opcional). O sistema vive no schema "montinho", o que
# permite instalá-lo dentro de um projeto Supabase que você já usa, sem
# colidir com outros apps. Só altere se usar um schema diferente nas migrações.
NEXT_PUBLIC_SUPABASE_SCHEMA=montinho

# -----------------------------------------------------------------------------
# IA opcional (V2) — enriquecimento da análise do recordatório alimentar.
# Sem estas variáveis, a análise segue 100% determinística (sem custo).
# ATENÇÃO: a IA gera custo por uso na Anthropic. Ative só se quiser.
# -----------------------------------------------------------------------------
# Chave secreta da Anthropic (server-only — nunca exposta ao navegador).
# ANTHROPIC_API_KEY=
# Modelo usado (opcional). Padrão: claude-haiku-4-5 (o mais barato atual).
# ANTHROPIC_MODEL=claude-haiku-4-5
# Ligue o botão "Aprofundar com IA" no app (defina junto com a chave acima).
# NEXT_PUBLIC_AI_ENABLED=true
